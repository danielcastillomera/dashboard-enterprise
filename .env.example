# ============================================
# DASHBOARD ENTERPRISE — Variables de Entorno
# Copie este archivo a .env.local y complete
# los valores para su entorno.
# ============================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Base de Datos (Prisma) ----
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Modo de Datos ----
# true  = usa Supabase/Prisma (producción)
# false = usa datos mock (desarrollo/demo)
USE_REAL_DB=true

# ---- Email (Resend) ----
# Obtén tu clave en https://resend.com
RESEND_API_KEY=re_xxxxx
# Dirección de envío (debe estar verificada en Resend)
EMAIL_FROM=noreply@yourdomain.com

# ---- URL de la App ----
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
