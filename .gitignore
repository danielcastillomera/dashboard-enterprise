# ============================================
# Dashboard Enterprise — .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
.pnp/
.pnp.js
.yarn/

# ---- Build & Output ----
.next/
out/
build/
dist/
*.tsbuildinfo

# ---- Environment & Secrets ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Prisma ----
prisma/*.db
prisma/*.db-journal

# ---- Debug & Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- OS Generated ----
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msp
*.msm
*.msi

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ---- IDEs & Editors ----
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# ---- Vercel ----
.vercel

# ---- Testing ----
coverage/
.nyc_output/

# ---- Misc ----
*.tgz
*.gz
*.zip
.cache/
.temp/
.tmp/
